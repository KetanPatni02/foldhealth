{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Fold Health",
  "colors": {
    "primary": "#8C5AE2",
    "light": "#A87FF0",
    "dark": "#7B4FCA"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
