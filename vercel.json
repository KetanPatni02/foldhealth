{
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://foldhealth.mintlify.app/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://foldhealth.mintlify.app/docs/:match*"
    }
  ]
}
